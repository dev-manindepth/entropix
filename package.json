{
  "name": "Entropix",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "tokens:build": "turbo run build --filter=@entropix/tokens",
    "test": "turbo run test",
    "storybook": "turbo run dev --filter=storybook",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "publish:dry": "turbo run build && pnpm -r publish --dry-run --no-git-checks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
