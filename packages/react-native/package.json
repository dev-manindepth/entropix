{
  "name": "@entropix/react-native",
  "version": "0.2.0",
  "description": "React Native components for the Entropix design system — iOS and Android with shared headless core",
  "type": "module",
  "license": "MIT",
  "author": "Manish <manindepth07@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-manindepth/entropix.git",
    "directory": "packages/react-native"
  },
  "bugs": {
    "url": "https://github.com/dev-manindepth/entropix/issues"
  },
  "homepage": "https://github.com/dev-manindepth/entropix/tree/main/packages/react-native",
  "keywords": [
    "design-system",
    "react-native",
    "components",
    "ui-library",
    "ios",
    "android",
    "accessible",
    "entropix"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch"
  },
  "dependencies": {
    "@entropix/core": "workspace:*",
    "@entropix/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.72"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@entropix/eslint-config": "workspace:*",
    "@entropix/typescript-config": "workspace:*",
    "@jest/types": "^29.6.3",
    "@react-native/babel-preset": "^0.84.1",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "19.2.2",
    "babel-jest": "^30.3.0",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "react": "^19.2.0",
    "react-native": "^0.76.0",
    "react-test-renderer": "^19.2.0",
    "ts-jest": "^29.3.0",
    "tsup": "^8.4.0",
    "typescript": "5.9.2"
  }
}
