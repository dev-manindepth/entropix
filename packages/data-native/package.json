{
  "name": "@entropix/data-native",
  "version": "1.0.1",
  "description": "React Native data components for the Entropix design system — DataTable with sorting, filtering, pagination, and selection",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "author": "Manish <manindepth07@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-manindepth/entropix.git",
    "directory": "packages/data-native"
  },
  "bugs": {
    "url": "https://github.com/dev-manindepth/entropix/issues"
  },
  "homepage": "https://github.com/dev-manindepth/entropix/tree/main/packages/data-native",
  "keywords": [
    "design-system",
    "react-native",
    "data-table",
    "components",
    "ui-library",
    "ios",
    "android",
    "accessible",
    "entropix"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./data-table": {
      "import": {
        "types": "./dist/data-table.d.ts",
        "default": "./dist/data-table.js"
      },
      "require": {
        "types": "./dist/data-table.d.cts",
        "default": "./dist/data-table.cjs"
      }
    },
    "./bar-chart": {
      "import": {
        "types": "./dist/bar-chart.d.ts",
        "default": "./dist/bar-chart.js"
      },
      "require": {
        "types": "./dist/bar-chart.d.cts",
        "default": "./dist/bar-chart.cjs"
      }
    },
    "./line-chart": {
      "import": {
        "types": "./dist/line-chart.d.ts",
        "default": "./dist/line-chart.js"
      },
      "require": {
        "types": "./dist/line-chart.d.cts",
        "default": "./dist/line-chart.cjs"
      }
    },
    "./area-chart": {
      "import": {
        "types": "./dist/area-chart.d.ts",
        "default": "./dist/area-chart.js"
      },
      "require": {
        "types": "./dist/area-chart.d.cts",
        "default": "./dist/area-chart.cjs"
      }
    },
    "./pie-chart": {
      "import": {
        "types": "./dist/pie-chart.d.ts",
        "default": "./dist/pie-chart.js"
      },
      "require": {
        "types": "./dist/pie-chart.d.cts",
        "default": "./dist/pie-chart.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "test": "echo \"no tests yet\""
  },
  "dependencies": {
    "@entropix/core": "workspace:*",
    "@entropix/tokens": "workspace:*"
  },
  "peerDependencies": {
    "@entropix/react-native": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.72",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@entropix/eslint-config": "workspace:*",
    "@entropix/typescript-config": "workspace:*",
    "@jest/types": "^29.6.3",
    "@react-native/babel-preset": "^0.84.1",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "19.2.2",
    "babel-jest": "^30.3.0",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "react": "^19.2.0",
    "react-native": "^0.76.0",
    "react-native-svg": "15",
    "react-test-renderer": "^19.2.0",
    "ts-jest": "^29.3.0",
    "tsup": "^8.4.0",
    "typescript": "5.9.2"
  }
}
