    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.4.0",
    "typescript": "5.9.2",
    "vitest": "^3.2.1"
  }
