{
  "name": "@entropix/core",
  "version": "1.0.1",
  "description": "Headless core hooks and utilities for the Entropix design system — platform-agnostic behavior, state, and accessibility",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "author": "Manish <manindepth07@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-manindepth/entropix.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/dev-manindepth/entropix/issues"
  },
  "homepage": "https://github.com/dev-manindepth/entropix/tree/main/packages/core",
  "keywords": [
    "design-system",
    "headless",
    "react-hooks",
    "accessibility",
    "wai-aria",
    "entropix"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./hooks/use-button": {
      "import": {
        "types": "./dist/hooks/use-button.d.ts",
