{
  "color": {
    "bg": {
      "primary":   { "$value": "{color.white}",    "$type": "color", "$description": "Primary background" },
      "secondary": { "$value": "{color.gray.50}",  "$type": "color", "$description": "Secondary/subtle background" },
      "tertiary":  { "$value": "{color.gray.100}", "$type": "color", "$description": "Tertiary/muted background" },
      "inverse":   { "$value": "{color.gray.900}", "$type": "color", "$description": "Inverse background for contrast" }
    },

    "text": {
      "primary":   { "$value": "{color.gray.900}", "$type": "color", "$description": "Primary text" },
      "secondary": { "$value": "{color.gray.600}", "$type": "color", "$description": "Secondary/muted text" },
      "tertiary":  { "$value": "{color.gray.400}", "$type": "color", "$description": "Tertiary/placeholder text" },
      "inverse":   { "$value": "{color.white}",    "$type": "color", "$description": "Text on inverse backgrounds" },
      "link":      { "$value": "{color.blue.600}", "$type": "color", "$description": "Link text" }
    },

    "border": {
      "default":  { "$value": "{color.gray.200}", "$type": "color", "$description": "Default border" },
      "strong":   { "$value": "{color.gray.300}", "$type": "color", "$description": "Strong/emphasized border" },
      "focus":    { "$value": "{color.blue.500}", "$type": "color", "$description": "Focus ring color" }
    },

    "action": {
      "primary": {
        "default": { "$value": "{color.blue.600}", "$type": "color", "$description": "Primary action default" },
        "hover":   { "$value": "{color.blue.700}", "$type": "color", "$description": "Primary action hover" },
        "active":  { "$value": "{color.blue.800}", "$type": "color", "$description": "Primary action active/pressed" }
      },
      "secondary": {
        "default": { "$value": "{color.gray.100}", "$type": "color", "$description": "Secondary action default" },
        "hover":   { "$value": "{color.gray.200}", "$type": "color", "$description": "Secondary action hover" },
        "active":  { "$value": "{color.gray.300}", "$type": "color", "$description": "Secondary action active/pressed" }
      }
    },

    "feedback": {
      "success":  { "$value": "{color.green.600}", "$type": "color", "$description": "Success state" },
      "warning":  { "$value": "{color.amber.500}", "$type": "color", "$description": "Warning state" },
      "error":    { "$value": "{color.red.600}",   "$type": "color", "$description": "Error/danger state" },
      "info":     { "$value": "{color.blue.600}",  "$type": "color", "$description": "Informational state" }
    },

    "feedback-bg": {
      "success":  { "$value": "{color.green.50}",  "$type": "color", "$description": "Success background" },
      "warning":  { "$value": "{color.amber.50}",  "$type": "color", "$description": "Warning background" },
      "error":    { "$value": "{color.red.50}",    "$type": "color", "$description": "Error background" },
      "info":     { "$value": "{color.blue.50}",   "$type": "color", "$description": "Info background" }
    }
  }
}
