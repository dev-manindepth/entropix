{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web-playground",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "web", "dev"],
      "port": 3000
    },
    {
      "name": "mobile-expo-web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8082"],
      "port": 8082,
      "cwd": "apps/mobile"
    },
    {
      "name": "demo",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "demo", "dev"],
      "port": 3001
    },
    {
      "name": "demo-mobile-web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8085"],
      "port": 8085,
      "cwd": "apps/demo-mobile"
    }
  ]
}
